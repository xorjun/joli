# Database
DATABASE_URL=sqlite:///./joli.db
# For production Postgres: DATABASE_URL=postgresql://user:pass@host:5432/joli

# JWT
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenRouter AI
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
CHAT_MODEL=deepseek/deepseek-chat-v3
DOCUMENT_MODEL=deepseek/deepseek-chat-v3

# App
APP_NAME=Joli
APP_ENV=development
DEBUG=true

# Upload limits
MAX_UPLOAD_SIZE_MB=5
